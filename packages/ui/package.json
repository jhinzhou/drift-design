{
  "name": "drift-design",
  "version": "1.0.1",
  "type": "module",
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./styles.css": "./dist/styles.css",
    "./component-meta.json": "./component-meta.json",
    "./vscode-custom-data.json": "./vscode-custom-data.json"
  },
  "files": [
    "dist",
    "component-meta.json",
    "vscode-custom-data.json"
  ],
  "sideEffects": [
    "**/*.css"
  ],
  "peerDependencies": {
    "vue": "^3.5.0"
  },
  "dependencies": {
    "@radix-icons/vue": "1.0.0",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "radix-vue": "1.9.17",
    "tailwind-merge": "3.5.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "4.2.2",
    "@vitejs/plugin-vue": "6.0.5",
    "@vue/test-utils": "2.4.6",
    "jsdom": "29.0.1",
    "shadcn-vue": "2.5.1",
    "tailwindcss": "4.2.2",
    "tslib": "2.8.1",
    "tsx": "4.21.0",
    "vite": "8.0.3",
    "vite-plugin-dts": "4.5.4",
    "vitest": "4.1.2",
    "vue": "3.5.32",
    "vue-tsc": "3.2.6"
  },
  "scripts": {
    "lint": "eslint \"src/**/*.{ts,vue}\" \"scripts/**/*.ts\" \"harness/**/*.ts\" --max-warnings=0",
    "test": "vitest run",
    "typecheck": "vue-tsc -p tsconfig.json --noEmit",
    "build": "vite build",
    "meta:generate": "tsx scripts/generate-meta.ts",
    "meta:check": "tsx scripts/check-meta.ts",
    "i18n:check": "tsx scripts/check-i18n.ts",
    "theme:check": "tsx scripts/check-theme.ts",
    "harness": "tsx harness/runners/run-harness.ts",
    "shadcn:init": "shadcn-vue init --yes --cwd .",
    "shadcn:add": "shadcn-vue add"
  }
}
