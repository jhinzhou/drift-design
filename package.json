{
  "name": "drift-ui",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.0.0",
  "scripts": {
    "lint": "pnpm -r run lint && pnpm i18n:check && pnpm theme:check",
    "test": "pnpm -r run test",
    "typecheck": "pnpm -r run typecheck",
    "build": "pnpm --filter @drift-ui/ui run meta:generate && pnpm -r run build",
    "harness": "pnpm --filter @drift-ui/ui run harness",
    "docs:build": "pnpm --filter @drift-ui/docs run build",
    "meta:check": "pnpm --filter @drift-ui/ui run meta:check",
    "i18n:check": "pnpm --filter @drift-ui/ui run i18n:check",
    "theme:check": "pnpm --filter @drift-ui/ui run theme:check",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release:verify": "pnpm lint && pnpm test && pnpm typecheck && pnpm build && pnpm harness && pnpm meta:check",
    "commitlint": "commitlint",
    "prepare": "simple-git-hooks"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm lint && pnpm typecheck",
    "commit-msg": "pnpm commitlint --edit $1"
  },
  "devDependencies": {
    "@commitlint/cli": "20.5.0",
    "@commitlint/config-conventional": "20.5.0",
    "@changesets/cli": "2.30.0",
    "@eslint/js": "10.0.1",
    "@types/node": "25.5.2",
    "@typescript-eslint/eslint-plugin": "8.58.0",
    "@typescript-eslint/parser": "8.58.0",
    "eslint": "10.2.0",
    "eslint-plugin-vue": "10.8.0",
    "globals": "17.4.0",
    "prettier": "3.8.1",
    "simple-git-hooks": "2.13.1",
    "typescript": "6.0.2",
    "typescript-eslint": "8.58.0",
    "vue-eslint-parser": "10.4.0"
  }
}
